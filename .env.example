# Axor Lab hosted pilot — copy to `.env` and fill in. Never commit `.env`.

# ── posture ──────────────────────────────────────────────────────────────────
# 1 = hosted: enforce workspace entitlements (paid Security features 402 below
# tier). 0 = self-hosted: unlimited local use, nothing gated.
AXOR_LAB_HOSTED=1

# ── auth (REQUIRED for a public deployment) ──────────────────────────────────
# Bearer token for every write (publish, import incident, approve). Generate a
# long random value: `openssl rand -hex 32`.
AXOR_LAB_WRITE_TOKEN=
# Bearer token for takedown (admin). Separate from the write token.
AXOR_LAB_ADMIN_TOKEN=
# Bearer token for the runtime-jobs control surface (plan / assign runs).
AXOR_LAB_CONTROL_TOKEN=

# ── entitlement (axor-packaging.md §4) ───────────────────────────────────────
# Vendor Ed25519 public key (hex) the license is verified against — the same key
# the Control Plane pins. Without it the server runs as the community tier.
AXOR_VENDOR_PUBKEY=
# Where the license file is mounted inside the container (compose maps
# ./secrets/license.json here). Issue one with `axor-license issue …`.
AXOR_LAB_LICENSE_FILE=/run/secrets/license.json
